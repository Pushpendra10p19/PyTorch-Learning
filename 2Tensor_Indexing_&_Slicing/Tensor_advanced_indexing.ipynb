   "source": [
    "# In Advanced indexing we find or select multiple specific indices\n",
    "import torch \n",
    "a = torch.tensor([10,20,30,40,50])\n",
    "print(a[[0,2,4]])\n",
    "\n",
    "# In 2D matrix ,   where we make pairs\n",
    "\n",
    "b = torch.tensor([\n",
    "    [10,20,30],\n",
    "    [40,50,60]\n",
    "])\n",
    "print(b[[1,0],[2,1]])"
   ]
  }
