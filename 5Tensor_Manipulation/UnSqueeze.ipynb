   "source": [
    "# Befor UnSqueeze..... \n",
    "import torch\n",
    "a = torch.tensor([10,20,30,40,50])\n",
    "print(a.shape)\n",
    "\n",
    "# After UnSqueeze.........\n",
    "print(a.unsqueeze(0).shape)\n",
    "\n",
    "# important Rule........\n",
    "# if unsqueeze(0)  ---->  [1,5]\n",
    "# if unsqueeze(1)  ---->  [5,1]\n",
    "\n",
    "print(a.unsqueeze(1).shape)\n"
   ]
  }
 ],
