   "source": [
    "# View()   ---> it is similar of reshape() but it is not create new memory as reshape().\n",
    "# it is view in different shape of existing memory\n",
    "import torch\n",
    "a = torch.arange(12)\n",
    "print(a.view(3,4))\n",
    "\n",
    "# important rule --->  it is work when continuous in tensor memory\n"
   ]
  }
