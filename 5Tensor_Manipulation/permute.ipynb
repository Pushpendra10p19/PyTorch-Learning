   "source": [
    "# permute() ---> it is used to change the order of dimensions\n",
    "# it is not change the data\n",
    "\n",
    "# Before permute()....\n",
    "import torch\n",
    "a = torch.randn(10,20,30) # dimension --> [0,1,2]\n",
    "print(a.shape)\n",
    "\n",
    "# After permute().....\n",
    "x = a.permute(2,0,1)\n",
    "print(x.shape)\n",
    "\n",
    "\n"
   ]
  }
 ],
